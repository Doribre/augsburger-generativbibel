[{"pk": 985400, "verse": 1, "text": "\u03b1\u03c1\u03c7\u03b7 \u03c4\u03bf\u03c5 \u03b5\u03c5\u03b1\u03b3\u03b3\u03b5\u03bb\u03b9\u03bf\u03c5 \u03b9\u03b7\u03c3\u03bf\u03c5 \u03c7\u03c1\u03b9\u03c3\u03c4\u03bf\u03c5"}, {"pk": 985401, "verse": 2, "text": "\u03ba\u03b1\u03b8\u03c9\u03c2 \u03b3\u03b5\u03b3\u03c1\u03b1\u03c0\u03c4\u03b1\u03b9 \u03b5\u03bd \u03c4\u03c9 \u03b7\u03c3\u03b1\u03b9\u03b1 \u03c4\u03c9 \u03c0\u03c1\u03bf\u03c6\u03b7\u03c4\u03b7 \u03b9\u03b4\u03bf\u03c5 \u03b5\u03b3\u03c9 \u03b1\u03c0\u03bf\u03c3\u03c4\u03b5\u03bb\u03bb\u03c9 \u03c4\u03bf\u03bd \u03b1\u03b3\u03b3\u03b5\u03bb\u03bf\u03bd \u03bc\u03bf\u03c5 \u03c0\u03c1\u03bf \u03c0\u03c1\u03bf\u03c3\u03c9\u03c0\u03bf\u03c5 \u03c3\u03bf\u03c5 \u03bf\u03c2 \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03b1\u03c3\u03b5\u03b9 \u03c4\u03b7\u03bd \u03bf\u03b4\u03bf\u03bd \u03c3\u03bf\u03c5"}, {"pk": 985402, "verse": 3, "text": "\u03c6\u03c9\u03bd\u03b7 \u03b2\u03bf\u03c9\u03bd\u03c4\u03bf\u03c2 \u03b5\u03bd \u03c4\u03b7 \u03b5\u03c1\u03b7\u03bc\u03c9 \u03b5\u03c4\u03bf\u03b9\u03bc\u03b1\u03c3\u03b1\u03c4\u03b5 \u03c4\u03b7\u03bd \u03bf\u03b4\u03bf\u03bd \u03ba\u03c5\u03c1\u03b9\u03bf\u03c5 \u03b5\u03c5\u03b8\u03b5\u03b9\u03b1\u03c2 \u03c0\u03bf\u03b9\u03b5\u03b9\u03c4\u03b5 \u03c4\u03b1\u03c2 \u03c4\u03c1\u03b9\u03b2\u03bf\u03c5\u03c2 \u03b1\u03c5\u03c4\u03bf\u03c5"}, {"pk": 985403, "verse": 4, "text": "\u03b5\u03b3\u03b5\u03bd\u03b5\u03c4\u03bf \u03b9\u03c9\u03b1\u03bd\u03bd\u03b7\u03c2 \u03bf \u03b2\u03b1\u03c0\u03c4\u03b9\u03b6\u03c9\u03bd \u03b5\u03bd \u03c4\u03b7 \u03b5\u03c1\u03b7\u03bc\u03c9 \u03ba\u03b1\u03b9 \u03ba\u03b7\u03c1\u03c5\u03c3\u03c3\u03c9\u03bd \u03b2\u03b1\u03c0\u03c4\u03b9\u03c3\u03bc\u03b1 \u03bc\u03b5\u03c4\u03b1\u03bd\u03bf\u03b9\u03b1\u03c2 \u03b5\u03b9\u03c2 \u03b1\u03c6\u03b5\u03c3\u03b9\u03bd \u03b1\u03bc\u03b1\u03c1\u03c4\u03b9\u03c9\u03bd"}, {"pk": 985404, "verse": 5, "text": "\u03ba\u03b1\u03b9 \u03b5\u03be\u03b5\u03c0\u03bf\u03c1\u03b5\u03c5\u03b5\u03c4\u03bf \u03c0\u03c1\u03bf\u03c2 \u03b1\u03c5\u03c4\u03bf\u03bd \u03c0\u03b1\u03c3\u03b1 \u03b7 \u03b9\u03bf\u03c5\u03b4\u03b1\u03b9\u03b1 \u03c7\u03c9\u03c1\u03b1 \u03ba\u03b1\u03b9 \u03bf\u03b9 \u03b9\u03b5\u03c1\u03bf\u03c3\u03bf\u03bb\u03c5\u03bc\u03b5\u03b9\u03c4\u03b1\u03b9 \u03c0\u03b1\u03bd\u03c4\u03b5\u03c2 \u03ba\u03b1\u03b9 \u03b5\u03b2\u03b1\u03c0\u03c4\u03b9\u03b6\u03bf\u03bd\u03c4\u03bf \u03c5\u03c0 \u03b1\u03c5\u03c4\u03bf\u03c5 \u03b5\u03bd \u03c4\u03c9 \u03b9\u03bf\u03c1\u03b4\u03b1\u03bd\u03b7 \u03c0\u03bf\u03c4\u03b1\u03bc\u03c9 \u03b5\u03be\u03bf\u03bc\u03bf\u03bb\u03bf\u03b3\u03bf\u03c5\u03bc\u03b5\u03bd\u03bf\u03b9 \u03c4\u03b1\u03c2 \u03b1\u03bc\u03b1\u03c1\u03c4\u03b9\u03b1\u03c2 \u03b1\u03c5\u03c4\u03c9\u03bd"}, {"pk": 985405, "verse": 6, "text": "\u03ba\u03b1\u03b9 \u03b7\u03bd \u03bf \u03b9\u03c9\u03b1\u03bd\u03bd\u03b7\u03c2 \u03b5\u03bd\u03b4\u03b5\u03b4\u03c5\u03bc\u03b5\u03bd\u03bf\u03c2 \u03c4\u03c1\u03b9\u03c7\u03b1\u03c2 \u03ba\u03b1\u03bc\u03b7\u03bb\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03b6\u03c9\u03bd\u03b7\u03bd \u03b4\u03b5\u03c1\u03bc\u03b1\u03c4\u03b9\u03bd\u03b7\u03bd \u03c0\u03b5\u03c1\u03b9 \u03c4\u03b7\u03bd \u03bf\u03c3\u03c6\u03c5\u03bd \u03b1\u03c5\u03c4\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03b5\u03c3\u03b8\u03b9\u03c9\u03bd \u03b1\u03ba\u03c1\u03b9\u03b4\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03bc\u03b5\u03bb\u03b9 \u03b1\u03b3\u03c1\u03b9\u03bf\u03bd"}, {"pk": 985406, "verse": 7, "text": "\u03ba\u03b1\u03b9 \u03b5\u03ba\u03b7\u03c1\u03c5\u03c3\u03c3\u03b5\u03bd \u03bb\u03b5\u03b3\u03c9\u03bd \u03b5\u03c1\u03c7\u03b5\u03c4\u03b1\u03b9 \u03bf \u03b9\u03c3\u03c7\u03c5\u03c1\u03bf\u03c4\u03b5\u03c1\u03bf\u03c2 \u03bc\u03bf\u03c5 \u03bf\u03c0\u03b9\u03c3\u03c9 \u03bc\u03bf\u03c5 \u03bf\u03c5 \u03bf\u03c5\u03ba \u03b5\u03b9\u03bc\u03b9 \u03b9\u03ba\u03b1\u03bd\u03bf\u03c2 \u03ba\u03c5\u03c8\u03b1\u03c2 \u03bb\u03c5\u03c3\u03b1\u03b9 \u03c4\u03bf\u03bd \u03b9\u03bc\u03b1\u03bd\u03c4\u03b1 \u03c4\u03c9\u03bd \u03c5\u03c0\u03bf\u03b4\u03b7\u03bc\u03b1\u03c4\u03c9\u03bd \u03b1\u03c5\u03c4\u03bf\u03c5"}, {"pk": 985407, "verse": 8, "text": "\u03b5\u03b3\u03c9 \u03b5\u03b2\u03b1\u03c0\u03c4\u03b9\u03c3\u03b1 \u03c5\u03bc\u03b1\u03c2 \u03c5\u03b4\u03b1\u03c4\u03b9 \u03b1\u03c5\u03c4\u03bf\u03c2 \u03b4\u03b5 \u03b2\u03b1\u03c0\u03c4\u03b9\u03c3\u03b5\u03b9 \u03c5\u03bc\u03b1\u03c2 \u03b5\u03bd \u03c0\u03bd\u03b5\u03c5\u03bc\u03b1\u03c4\u03b9 \u03b1\u03b3\u03b9\u03c9"}, {"pk": 985408, "verse": 9, "text": "\u03ba\u03b1\u03b9 \u03b5\u03b3\u03b5\u03bd\u03b5\u03c4\u03bf \u03b5\u03bd \u03b5\u03ba\u03b5\u03b9\u03bd\u03b1\u03b9\u03c2 \u03c4\u03b1\u03b9\u03c2 \u03b7\u03bc\u03b5\u03c1\u03b1\u03b9\u03c2 \u03b7\u03bb\u03b8\u03b5\u03bd \u03b9\u03b7\u03c3\u03bf\u03c5\u03c2 \u03b1\u03c0\u03bf \u03bd\u03b1\u03b6\u03b1\u03c1\u03b5\u03c4 \u03c4\u03b7\u03c2 \u03b3\u03b1\u03bb\u03b9\u03bb\u03b1\u03b9\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03b5\u03b2\u03b1\u03c0\u03c4\u03b9\u03c3\u03b8\u03b7 \u03b5\u03b9\u03c2 \u03c4\u03bf\u03bd \u03b9\u03bf\u03c1\u03b4\u03b1\u03bd\u03b7\u03bd \u03c5\u03c0\u03bf \u03b9\u03c9\u03b1\u03bd\u03bd\u03bf\u03c5"}, {"pk": 985409, "verse": 10, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b1\u03bd\u03b1\u03b2\u03b1\u03b9\u03bd\u03c9\u03bd \u03b5\u03ba \u03c4\u03bf\u03c5 \u03c5\u03b4\u03b1\u03c4\u03bf\u03c2 \u03b5\u03b9\u03b4\u03b5\u03bd \u03c3\u03c7\u03b9\u03b6\u03bf\u03bc\u03b5\u03bd\u03bf\u03c5\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03bf\u03c5\u03c1\u03b1\u03bd\u03bf\u03c5\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03bf \u03c0\u03bd\u03b5\u03c5\u03bc\u03b1 \u03c9\u03c2 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c4\u03b5\u03c1\u03b1\u03bd \u03ba\u03b1\u03c4\u03b1\u03b2\u03b1\u03b9\u03bd\u03bf\u03bd \u03b5\u03b9\u03c2 \u03b1\u03c5\u03c4\u03bf\u03bd"}, {"pk": 985410, "verse": 11, "text": "\u03ba\u03b1\u03b9 \u03c6\u03c9\u03bd\u03b7 \u03b5\u03ba \u03c4\u03c9\u03bd \u03bf\u03c5\u03c1\u03b1\u03bd\u03c9\u03bd \u03c3\u03c5 \u03b5\u03b9 \u03bf \u03c5\u03b9\u03bf\u03c2 \u03bc\u03bf\u03c5 \u03bf \u03b1\u03b3\u03b1\u03c0\u03b7\u03c4\u03bf\u03c2 \u03b5\u03bd \u03c3\u03bf\u03b9 \u03b5\u03c5\u03b4\u03bf\u03ba\u03b7\u03c3\u03b1"}, {"pk": 985411, "verse": 12, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03c4\u03bf \u03c0\u03bd\u03b5\u03c5\u03bc\u03b1 \u03b1\u03c5\u03c4\u03bf\u03bd \u03b5\u03ba\u03b2\u03b1\u03bb\u03bb\u03b5\u03b9 \u03b5\u03b9\u03c2 \u03c4\u03b7\u03bd \u03b5\u03c1\u03b7\u03bc\u03bf\u03bd"}, {"pk": 985412, "verse": 13, "text": "\u03ba\u03b1\u03b9 \u03b7\u03bd \u03b5\u03bd \u03c4\u03b7 \u03b5\u03c1\u03b7\u03bc\u03c9 \u03c4\u03b5\u03c3\u03c3\u03b5\u03c1\u03b1\u03ba\u03bf\u03bd\u03c4\u03b1 \u03b7\u03bc\u03b5\u03c1\u03b1\u03c2 \u03c0\u03b5\u03b9\u03c1\u03b1\u03b6\u03bf\u03bc\u03b5\u03bd\u03bf\u03c2 \u03c5\u03c0\u03bf \u03c4\u03bf\u03c5 \u03c3\u03b1\u03c4\u03b1\u03bd\u03b1 \u03ba\u03b1\u03b9 \u03b7\u03bd \u03bc\u03b5\u03c4\u03b1 \u03c4\u03c9\u03bd \u03b8\u03b7\u03c1\u03b9\u03c9\u03bd \u03ba\u03b1\u03b9 \u03bf\u03b9 \u03b1\u03b3\u03b3\u03b5\u03bb\u03bf\u03b9 \u03b4\u03b9\u03b7\u03ba\u03bf\u03bd\u03bf\u03c5\u03bd \u03b1\u03c5\u03c4\u03c9"}, {"pk": 985413, "verse": 14, "text": "\u03bc\u03b5\u03c4\u03b1 \u03b4\u03b5 \u03c4\u03bf \u03c0\u03b1\u03c1\u03b1\u03b4\u03bf\u03b8\u03b7\u03bd\u03b1\u03b9 \u03c4\u03bf\u03bd \u03b9\u03c9\u03b1\u03bd\u03bd\u03b7\u03bd \u03b7\u03bb\u03b8\u03b5\u03bd \u03bf \u03b9\u03b7\u03c3\u03bf\u03c5\u03c2 \u03b5\u03b9\u03c2 \u03c4\u03b7\u03bd \u03b3\u03b1\u03bb\u03b9\u03bb\u03b1\u03b9\u03b1\u03bd \u03ba\u03b7\u03c1\u03c5\u03c3\u03c3\u03c9\u03bd \u03c4\u03bf \u03b5\u03c5\u03b1\u03b3\u03b3\u03b5\u03bb\u03b9\u03bf\u03bd \u03c4\u03bf\u03c5 \u03b8\u03b5\u03bf\u03c5"}, {"pk": 985414, "verse": 15, "text": "\u03bf\u03c4\u03b9 \u03c0\u03b5\u03c0\u03bb\u03b7\u03c1\u03c9\u03c4\u03b1\u03b9 \u03bf \u03ba\u03b1\u03b9\u03c1\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03b7\u03b3\u03b3\u03b9\u03ba\u03b5\u03bd \u03b7 \u03b2\u03b1\u03c3\u03b9\u03bb\u03b5\u03b9\u03b1 \u03c4\u03bf\u03c5 \u03b8\u03b5\u03bf\u03c5 \u03bc\u03b5\u03c4\u03b1\u03bd\u03bf\u03b5\u03b9\u03c4\u03b5 \u03ba\u03b1\u03b9 \u03c0\u03b9\u03c3\u03c4\u03b5\u03c5\u03b5\u03c4\u03b5 \u03b5\u03bd \u03c4\u03c9 \u03b5\u03c5\u03b1\u03b3\u03b3\u03b5\u03bb\u03b9\u03c9"}, {"pk": 985415, "verse": 16, "text": "\u03ba\u03b1\u03b9 \u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03bd \u03c0\u03b1\u03c1\u03b1 \u03c4\u03b7\u03bd \u03b8\u03b1\u03bb\u03b1\u03c3\u03c3\u03b1\u03bd \u03c4\u03b7\u03c2 \u03b3\u03b1\u03bb\u03b9\u03bb\u03b1\u03b9\u03b1\u03c2 \u03b5\u03b9\u03b4\u03b5\u03bd \u03c3\u03b9\u03bc\u03c9\u03bd\u03b1 \u03ba\u03b1\u03b9 \u03b1\u03bd\u03b4\u03c1\u03b5\u03b1\u03bd \u03c4\u03bf\u03bd \u03b1\u03b4\u03b5\u03bb\u03c6\u03bf\u03bd \u03c3\u03b9\u03bc\u03c9\u03bd\u03bf\u03c2 \u03b1\u03bc\u03c6\u03b9\u03b2\u03b1\u03bb\u03bb\u03bf\u03bd\u03c4\u03b1\u03c2 \u03b5\u03bd \u03c4\u03b7 \u03b8\u03b1\u03bb\u03b1\u03c3\u03c3\u03b7 \u03b7\u03c3\u03b1\u03bd \u03b3\u03b1\u03c1 \u03b1\u03bb\u03b5\u03b5\u03b9\u03c2"}, {"pk": 985416, "verse": 17, "text": "\u03ba\u03b1\u03b9 \u03b5\u03b9\u03c0\u03b5\u03bd \u03b1\u03c5\u03c4\u03bf\u03b9\u03c2 \u03bf \u03b9\u03b7\u03c3\u03bf\u03c5\u03c2 \u03b4\u03b5\u03c5\u03c4\u03b5 \u03bf\u03c0\u03b9\u03c3\u03c9 \u03bc\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03c0\u03bf\u03b9\u03b7\u03c3\u03c9 \u03c5\u03bc\u03b1\u03c2 \u03b3\u03b5\u03bd\u03b5\u03c3\u03b8\u03b1\u03b9 \u03b1\u03bb\u03b5\u03b5\u03b9\u03c2 \u03b1\u03bd\u03b8\u03c1\u03c9\u03c0\u03c9\u03bd"}, {"pk": 985417, "verse": 18, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b1\u03c6\u03b5\u03bd\u03c4\u03b5\u03c2 \u03c4\u03b1 \u03b4\u03b9\u03ba\u03c4\u03c5\u03b1 \u03b7\u03ba\u03bf\u03bb\u03bf\u03c5\u03b8\u03b7\u03c3\u03b1\u03bd \u03b1\u03c5\u03c4\u03c9"}, {"pk": 985418, "verse": 19, "text": "\u03ba\u03b1\u03b9 \u03c0\u03c1\u03bf\u03b2\u03b1\u03c2 \u03bf\u03bb\u03b9\u03b3\u03bf\u03bd \u03b5\u03b9\u03b4\u03b5\u03bd \u03b9\u03b1\u03ba\u03c9\u03b2\u03bf\u03bd \u03c4\u03bf\u03bd \u03c4\u03bf\u03c5 \u03b6\u03b5\u03b2\u03b5\u03b4\u03b1\u03b9\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03b9\u03c9\u03b1\u03bd\u03bd\u03b7\u03bd \u03c4\u03bf\u03bd \u03b1\u03b4\u03b5\u03bb\u03c6\u03bf\u03bd \u03b1\u03c5\u03c4\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03b1\u03c5\u03c4\u03bf\u03c5\u03c2 \u03b5\u03bd \u03c4\u03c9 \u03c0\u03bb\u03bf\u03b9\u03c9 \u03ba\u03b1\u03c4\u03b1\u03c1\u03c4\u03b9\u03b6\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c4\u03b1 \u03b4\u03b9\u03ba\u03c4\u03c5\u03b1"}, {"pk": 985419, "verse": 20, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b5\u03ba\u03b1\u03bb\u03b5\u03c3\u03b5\u03bd \u03b1\u03c5\u03c4\u03bf\u03c5\u03c2 \u03ba\u03b1\u03b9 \u03b1\u03c6\u03b5\u03bd\u03c4\u03b5\u03c2 \u03c4\u03bf\u03bd \u03c0\u03b1\u03c4\u03b5\u03c1\u03b1 \u03b1\u03c5\u03c4\u03c9\u03bd \u03b6\u03b5\u03b2\u03b5\u03b4\u03b1\u03b9\u03bf\u03bd \u03b5\u03bd \u03c4\u03c9 \u03c0\u03bb\u03bf\u03b9\u03c9 \u03bc\u03b5\u03c4\u03b1 \u03c4\u03c9\u03bd \u03bc\u03b9\u03c3\u03b8\u03c9\u03c4\u03c9\u03bd \u03b1\u03c0\u03b7\u03bb\u03b8\u03bf\u03bd \u03bf\u03c0\u03b9\u03c3\u03c9 \u03b1\u03c5\u03c4\u03bf\u03c5"}, {"pk": 985420, "verse": 21, "text": "\u03ba\u03b1\u03b9 \u03b5\u03b9\u03c3\u03c0\u03bf\u03c1\u03b5\u03c5\u03bf\u03bd\u03c4\u03b1\u03b9 \u03b5\u03b9\u03c2 \u03ba\u03b1\u03c6\u03b1\u03c1\u03bd\u03b1\u03bf\u03c5\u03bc \u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03c4\u03bf\u03b9\u03c2 \u03c3\u03b1\u03b2\u03b2\u03b1\u03c3\u03b9\u03bd \u03b5\u03b4\u03b9\u03b4\u03b1\u03c3\u03ba\u03b5\u03bd \u03b5\u03b9\u03c2 \u03c4\u03b7\u03bd \u03c3\u03c5\u03bd\u03b1\u03b3\u03c9\u03b3\u03b7\u03bd\u03bd"}, {"pk": 985421, "verse": 22, "text": "\u03ba\u03b1\u03b9 \u03b5\u03be\u03b5\u03c0\u03bb\u03b7\u03c3\u03c3\u03bf\u03bd\u03c4\u03bf \u03b5\u03c0\u03b9 \u03c4\u03b7 \u03b4\u03b9\u03b4\u03b1\u03c7\u03b7 \u03b1\u03c5\u03c4\u03bf\u03c5 \u03b7\u03bd \u03b3\u03b1\u03c1 \u03b4\u03b9\u03b4\u03b1\u03c3\u03ba\u03c9\u03bd \u03b1\u03c5\u03c4\u03bf\u03c5\u03c2 \u03c9\u03c2 \u03b5\u03be\u03bf\u03c5\u03c3\u03b9\u03b1\u03bd \u03b5\u03c7\u03c9\u03bd \u03ba\u03b1\u03b9 \u03bf\u03c5\u03c7 \u03c9\u03c2 \u03bf\u03b9 \u03b3\u03c1\u03b1\u03bc\u03bc\u03b1\u03c4\u03b5\u03b9\u03c2"}, {"pk": 985422, "verse": 23, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b7\u03bd \u03b5\u03bd \u03c4\u03b7 \u03c3\u03c5\u03bd\u03b1\u03b3\u03c9\u03b3\u03b7 \u03b1\u03c5\u03c4\u03c9\u03bd \u03b1\u03bd\u03b8\u03c1\u03c9\u03c0\u03bf\u03c2 \u03b5\u03bd \u03c0\u03bd\u03b5\u03c5\u03bc\u03b1\u03c4\u03b9 \u03b1\u03ba\u03b1\u03b8\u03b1\u03c1\u03c4\u03c9 \u03ba\u03b1\u03b9 \u03b1\u03bd\u03b5\u03ba\u03c1\u03b1\u03be\u03b5\u03bd"}, {"pk": 985423, "verse": 24, "text": "\u03bb\u03b5\u03b3\u03c9\u03bd \u03c4\u03b9 \u03b7\u03bc\u03b9\u03bd \u03ba\u03b1\u03b9 \u03c3\u03bf\u03b9 \u03b9\u03b7\u03c3\u03bf\u03c5 \u03bd\u03b1\u03b6\u03b1\u03c1\u03b7\u03bd\u03b5 \u03b7\u03bb\u03b8\u03b5\u03c2 \u03b1\u03c0\u03bf\u03bb\u03b5\u03c3\u03b1\u03b9 \u03b7\u03bc\u03b1\u03c2 \u03bf\u03b9\u03b4\u03b1\u03bc\u03b5\u03bd \u03c3\u03b5 \u03c4\u03b9\u03c2 \u03b5\u03b9 \u03bf \u03b1\u03b3\u03b9\u03bf\u03c2 \u03c4\u03bf\u03c5 \u03b8\u03b5\u03bf\u03c5"}, {"pk": 985424, "verse": 25, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c0\u03b5\u03c4\u03b9\u03bc\u03b7\u03c3\u03b5\u03bd \u03b1\u03c5\u03c4\u03c9 \u03bf \u03b9\u03b7\u03c3\u03bf\u03c5\u03c2 \u03c6\u03b9\u03bc\u03c9\u03b8\u03b7\u03c4\u03b9 \u03ba\u03b1\u03b9 \u03b5\u03be\u03b5\u03bb\u03b8\u03b5 \u03b5\u03be \u03b1\u03c5\u03c4\u03bf\u03c5"}, {"pk": 985425, "verse": 26, "text": "\u03ba\u03b1\u03b9 \u03c3\u03c0\u03b1\u03c1\u03b1\u03be\u03b1\u03bd \u03b1\u03c5\u03c4\u03bf\u03bd \u03c4\u03bf \u03c0\u03bd\u03b5\u03c5\u03bc\u03b1 \u03c4\u03bf \u03b1\u03ba\u03b1\u03b8\u03b1\u03c1\u03c4\u03bf\u03bd \u03ba\u03b1\u03b9 \u03c6\u03c9\u03bd\u03b7\u03c3\u03b1\u03bd \u03c6\u03c9\u03bd\u03b7 \u03bc\u03b5\u03b3\u03b1\u03bb\u03b7 \u03b5\u03be\u03b7\u03bb\u03b8\u03b5\u03bd \u03b5\u03be \u03b1\u03c5\u03c4\u03bf\u03c5"}, {"pk": 985426, "verse": 27, "text": "\u03ba\u03b1\u03b9 \u03b5\u03b8\u03b1\u03bc\u03b2\u03b7\u03b8\u03b7\u03c3\u03b1\u03bd \u03b1\u03c0\u03b1\u03bd\u03c4\u03b5\u03c2 \u03c9\u03c3\u03c4\u03b5 \u03c3\u03c5\u03b6\u03b7\u03c4\u03b5\u03b9\u03bd \u03b1\u03c5\u03c4\u03bf\u03c5\u03c2 \u03bb\u03b5\u03b3\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c4\u03b9 \u03b5\u03c3\u03c4\u03b9\u03bd \u03c4\u03bf\u03c5\u03c4\u03bf \u03b4\u03b9\u03b4\u03b1\u03c7\u03b7 \u03ba\u03b1\u03b9\u03bd\u03b7 \u03ba\u03b1\u03c4 \u03b5\u03be\u03bf\u03c5\u03c3\u03b9\u03b1\u03bd \u03ba\u03b1\u03b9 \u03c4\u03bf\u03b9\u03c2 \u03c0\u03bd\u03b5\u03c5\u03bc\u03b1\u03c3\u03b9 \u03c4\u03bf\u03b9\u03c2 \u03b1\u03ba\u03b1\u03b8\u03b1\u03c1\u03c4\u03bf\u03b9\u03c2 \u03b5\u03c0\u03b9\u03c4\u03b1\u03c3\u03c3\u03b5\u03b9 \u03ba\u03b1\u03b9 \u03c5\u03c0\u03b1\u03ba\u03bf\u03c5\u03bf\u03c5\u03c3\u03b9\u03bd \u03b1\u03c5\u03c4\u03c9"}, {"pk": 985427, "verse": 28, "text": "\u03ba\u03b1\u03b9 \u03b5\u03be\u03b7\u03bb\u03b8\u03b5\u03bd \u03b7 \u03b1\u03ba\u03bf\u03b7 \u03b1\u03c5\u03c4\u03bf\u03c5 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03c0\u03b1\u03bd\u03c4\u03b1\u03c7\u03bf\u03c5 \u03b5\u03b9\u03c2 \u03bf\u03bb\u03b7\u03bd \u03c4\u03b7\u03bd \u03c0\u03b5\u03c1\u03b9\u03c7\u03c9\u03c1\u03bf\u03bd \u03c4\u03b7\u03c2 \u03b3\u03b1\u03bb\u03b9\u03bb\u03b1\u03b9\u03b1\u03c2"}, {"pk": 985428, "verse": 29, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b5\u03ba \u03c4\u03b7\u03c2 \u03c3\u03c5\u03bd\u03b1\u03b3\u03c9\u03b3\u03b7\u03c2 \u03b5\u03be\u03b5\u03bb\u03b8\u03bf\u03bd\u03c4\u03b5\u03c2 \u03b7\u03bb\u03b8\u03bf\u03bd \u03b5\u03b9\u03c2 \u03c4\u03b7\u03bd \u03bf\u03b9\u03ba\u03b9\u03b1\u03bd \u03c3\u03b9\u03bc\u03c9\u03bd\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03b1\u03bd\u03b4\u03c1\u03b5\u03bf\u03c5 \u03bc\u03b5\u03c4\u03b1 \u03b9\u03b1\u03ba\u03c9\u03b2\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03b9\u03c9\u03b1\u03bd\u03bd\u03bf\u03c5"}, {"pk": 985429, "verse": 30, "text": "\u03b7 \u03b4\u03b5 \u03c0\u03b5\u03bd\u03b8\u03b5\u03c1\u03b1 \u03c3\u03b9\u03bc\u03c9\u03bd\u03bf\u03c2 \u03ba\u03b1\u03c4\u03b5\u03ba\u03b5\u03b9\u03c4\u03bf \u03c0\u03c5\u03c1\u03b5\u03c3\u03c3\u03bf\u03c5\u03c3\u03b1 \u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03bb\u03b5\u03b3\u03bf\u03c5\u03c3\u03b9\u03bd \u03b1\u03c5\u03c4\u03c9 \u03c0\u03b5\u03c1\u03b9 \u03b1\u03c5\u03c4\u03b7\u03c2"}, {"pk": 985430, "verse": 31, "text": "\u03ba\u03b1\u03b9 \u03c0\u03c1\u03bf\u03c3\u03b5\u03bb\u03b8\u03c9\u03bd \u03b7\u03b3\u03b5\u03b9\u03c1\u03b5\u03bd \u03b1\u03c5\u03c4\u03b7\u03bd \u03ba\u03c1\u03b1\u03c4\u03b7\u03c3\u03b1\u03c2 \u03c4\u03b7\u03c2 \u03c7\u03b5\u03b9\u03c1\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03b1\u03c6\u03b7\u03ba\u03b5\u03bd \u03b1\u03c5\u03c4\u03b7\u03bd \u03bf \u03c0\u03c5\u03c1\u03b5\u03c4\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03b4\u03b9\u03b7\u03ba\u03bf\u03bd\u03b5\u03b9 \u03b1\u03c5\u03c4\u03bf\u03b9\u03c2"}, {"pk": 985431, "verse": 32, "text": "\u03bf\u03c8\u03b9\u03b1\u03c2 \u03b4\u03b5 \u03b3\u03b5\u03bd\u03bf\u03bc\u03b5\u03bd\u03b7\u03c2 \u03bf\u03c4\u03b5 \u03b5\u03b4\u03c5 \u03bf \u03b7\u03bb\u03b9\u03bf\u03c2 \u03b5\u03c6\u03b5\u03c1\u03bf\u03bd \u03c0\u03c1\u03bf\u03c2 \u03b1\u03c5\u03c4\u03bf\u03bd \u03c0\u03b1\u03bd\u03c4\u03b1\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03ba\u03b1\u03ba\u03c9\u03c2 \u03b5\u03c7\u03bf\u03bd\u03c4\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03bf\u03c5\u03c2 \u03b4\u03b1\u03b9\u03bc\u03bf\u03bd\u03b9\u03b6\u03bf\u03bc\u03b5\u03bd\u03bf\u03c5\u03c2"}, {"pk": 985432, "verse": 33, "text": "\u03ba\u03b1\u03b9 \u03b7\u03bd \u03bf\u03bb\u03b7 \u03b7 \u03c0\u03bf\u03bb\u03b9\u03c2 \u03b5\u03c0\u03b9\u03c3\u03c5\u03bd\u03b7\u03b3\u03bc\u03b5\u03bd\u03b7 \u03c0\u03c1\u03bf\u03c2 \u03c4\u03b7\u03bd \u03b8\u03c5\u03c1\u03b1\u03bd"}, {"pk": 985433, "verse": 34, "text": "\u03ba\u03b1\u03b9 \u03b5\u03b8\u03b5\u03c1\u03b1\u03c0\u03b5\u03c5\u03c3\u03b5\u03bd \u03c0\u03bf\u03bb\u03bb\u03bf\u03c5\u03c2 \u03ba\u03b1\u03ba\u03c9\u03c2 \u03b5\u03c7\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c0\u03bf\u03b9\u03ba\u03b9\u03bb\u03b1\u03b9\u03c2 \u03bd\u03bf\u03c3\u03bf\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03b4\u03b1\u03b9\u03bc\u03bf\u03bd\u03b9\u03b1 \u03c0\u03bf\u03bb\u03bb\u03b1 \u03b5\u03be\u03b5\u03b2\u03b1\u03bb\u03b5\u03bd \u03ba\u03b1\u03b9 \u03bf\u03c5\u03ba \u03b7\u03c6\u03b9\u03b5\u03bd \u03bb\u03b1\u03bb\u03b5\u03b9\u03bd \u03c4\u03b1 \u03b4\u03b1\u03b9\u03bc\u03bf\u03bd\u03b9\u03b1 \u03bf\u03c4\u03b9 \u03b7\u03b4\u03b5\u03b9\u03c3\u03b1\u03bd \u03b1\u03c5\u03c4\u03bf\u03bd"}, {"pk": 985434, "verse": 35, "text": "\u03ba\u03b1\u03b9 \u03c0\u03c1\u03c9\u03b9 \u03b5\u03bd\u03bd\u03c5\u03c7\u03b1 \u03bb\u03b9\u03b1\u03bd \u03b1\u03bd\u03b1\u03c3\u03c4\u03b1\u03c2 \u03b5\u03be\u03b7\u03bb\u03b8\u03b5\u03bd \u03ba\u03b1\u03b9 \u03b1\u03c0\u03b7\u03bb\u03b8\u03b5\u03bd \u03b5\u03b9\u03c2 \u03b5\u03c1\u03b7\u03bc\u03bf\u03bd \u03c4\u03bf\u03c0\u03bf\u03bd \u03ba\u03b1\u03ba\u03b5\u03b9 \u03c0\u03c1\u03bf\u03c3\u03b7\u03c5\u03c7\u03b5\u03c4\u03bf"}, {"pk": 985435, "verse": 36, "text": "\u03ba\u03b1\u03b9 \u03ba\u03b1\u03c4\u03b5\u03b4\u03b9\u03c9\u03be\u03b5\u03bd \u03b1\u03c5\u03c4\u03bf\u03bd \u03c3\u03b9\u03bc\u03c9\u03bd \u03ba\u03b1\u03b9 \u03bf\u03b9 \u03bc\u03b5\u03c4 \u03b1\u03c5\u03c4\u03bf\u03c5"}, {"pk": 985436, "verse": 37, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03c1\u03bf\u03bd \u03b1\u03c5\u03c4\u03bf\u03bd \u03ba\u03b1\u03b9 \u03bb\u03b5\u03b3\u03bf\u03c5\u03c3\u03b9\u03bd \u03b1\u03c5\u03c4\u03c9 \u03bf\u03c4\u03b9 \u03c0\u03b1\u03bd\u03c4\u03b5\u03c2 \u03b6\u03b7\u03c4\u03bf\u03c5\u03c3\u03b9\u03bd \u03c3\u03b5"}, {"pk": 985437, "verse": 38, "text": "\u03ba\u03b1\u03b9 \u03bb\u03b5\u03b3\u03b5\u03b9 \u03b1\u03c5\u03c4\u03bf\u03b9\u03c2 \u03b1\u03b3\u03c9\u03bc\u03b5\u03bd \u03b1\u03bb\u03bb\u03b1\u03c7\u03bf\u03c5 \u03b5\u03b9\u03c2 \u03c4\u03b1\u03c2 \u03b5\u03c7\u03bf\u03bc\u03b5\u03bd\u03b1\u03c2 \u03ba\u03c9\u03bc\u03bf\u03c0\u03bf\u03bb\u03b5\u03b9\u03c2 \u03b9\u03bd\u03b1 \u03ba\u03b1\u03ba\u03b5\u03b9 \u03ba\u03b7\u03c1\u03c5\u03be\u03c9 \u03b5\u03b9\u03c2 \u03c4\u03bf\u03c5\u03c4\u03bf \u03b3\u03b1\u03c1 \u03b5\u03be\u03b7\u03bb\u03b8\u03bf\u03bd"}, {"pk": 985438, "verse": 39, "text": "\u03ba\u03b1\u03b9 \u03b7\u03bb\u03b8\u03b5\u03bd \u03ba\u03b7\u03c1\u03c5\u03c3\u03c3\u03c9\u03bd \u03b5\u03b9\u03c2 \u03c4\u03b1\u03c2 \u03c3\u03c5\u03bd\u03b1\u03b3\u03c9\u03b3\u03b1\u03c2 \u03b1\u03c5\u03c4\u03c9\u03bd \u03b5\u03b9\u03c2 \u03bf\u03bb\u03b7\u03bd \u03c4\u03b7\u03bd \u03b3\u03b1\u03bb\u03b9\u03bb\u03b1\u03b9\u03b1\u03bd \u03ba\u03b1\u03b9 \u03c4\u03b1 \u03b4\u03b1\u03b9\u03bc\u03bf\u03bd\u03b9\u03b1 \u03b5\u03ba\u03b2\u03b1\u03bb\u03bb\u03c9\u03bd"}, {"pk": 985439, "verse": 40, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c1\u03c7\u03b5\u03c4\u03b1\u03b9 \u03c0\u03c1\u03bf\u03c2 \u03b1\u03c5\u03c4\u03bf\u03bd \u03bb\u03b5\u03c0\u03c1\u03bf\u03c2 \u03c0\u03b1\u03c1\u03b1\u03ba\u03b1\u03bb\u03c9\u03bd \u03b1\u03c5\u03c4\u03bf\u03bd \u03ba\u03b1\u03b9 \u03b3\u03bf\u03bd\u03c5\u03c0\u03b5\u03c4\u03c9\u03bd \u03bb\u03b5\u03b3\u03c9\u03bd \u03b1\u03c5\u03c4\u03c9 \u03bf\u03c4\u03b9 \u03b5\u03b1\u03bd \u03b8\u03b5\u03bb\u03b7\u03c2 \u03b4\u03c5\u03bd\u03b1\u03c3\u03b1\u03b9 \u03bc\u03b5 \u03ba\u03b1\u03b8\u03b1\u03c1\u03b9\u03c3\u03b1\u03b9"}, {"pk": 985440, "verse": 41, "text": "\u03ba\u03b1\u03b9 \u03c3\u03c0\u03bb\u03b1\u03b3\u03c7\u03bd\u03b9\u03c3\u03b8\u03b5\u03b9\u03c2 \u03b5\u03ba\u03c4\u03b5\u03b9\u03bd\u03b1\u03c2 \u03c4\u03b7\u03bd \u03c7\u03b5\u03b9\u03c1\u03b1 \u03b1\u03c5\u03c4\u03bf\u03c5 \u03b7\u03c8\u03b1\u03c4\u03bf \u03ba\u03b1\u03b9 \u03bb\u03b5\u03b3\u03b5\u03b9 \u03b8\u03b5\u03bb\u03c9 \u03ba\u03b1\u03b8\u03b1\u03c1\u03b9\u03c3\u03b8\u03b7\u03c4\u03b9"}, {"pk": 985441, "verse": 42, "text": "\u03ba\u03b1\u03b9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b1\u03c0\u03b7\u03bb\u03b8\u03b5\u03bd \u03b1\u03c0 \u03b1\u03c5\u03c4\u03bf\u03c5 \u03b7 \u03bb\u03b5\u03c0\u03c1\u03b1 \u03ba\u03b1\u03b9 \u03b5\u03ba\u03b1\u03b8\u03b5\u03c1\u03b9\u03c3\u03b8\u03b7"}, {"pk": 985442, "verse": 43, "text": "\u03ba\u03b1\u03b9 \u03b5\u03bc\u03b2\u03c1\u03b9\u03bc\u03b7\u03c3\u03b1\u03bc\u03b5\u03bd\u03bf\u03c2 \u03b1\u03c5\u03c4\u03c9 \u03b5\u03c5\u03b8\u03c5\u03c2 \u03b5\u03be\u03b5\u03b2\u03b1\u03bb\u03b5\u03bd \u03b1\u03c5\u03c4\u03bf\u03bd"}, {"pk": 985443, "verse": 44, "text": "\u03ba\u03b1\u03b9 \u03bb\u03b5\u03b3\u03b5\u03b9 \u03b1\u03c5\u03c4\u03c9 \u03bf\u03c1\u03b1 \u03bc\u03b7\u03b4\u03b5\u03bd\u03b9 \u03bc\u03b7\u03b4\u03b5\u03bd \u03b5\u03b9\u03c0\u03b7\u03c2 \u03b1\u03bb\u03bb\u03b1 \u03c5\u03c0\u03b1\u03b3\u03b5 \u03c3\u03b5\u03b1\u03c5\u03c4\u03bf\u03bd \u03b4\u03b5\u03b9\u03be\u03bf\u03bd \u03c4\u03c9 \u03b9\u03b5\u03c1\u03b5\u03b9 \u03ba\u03b1\u03b9 \u03c0\u03c1\u03bf\u03c3\u03b5\u03bd\u03b5\u03b3\u03ba\u03b5 \u03c0\u03b5\u03c1\u03b9 \u03c4\u03bf\u03c5 \u03ba\u03b1\u03b8\u03b1\u03c1\u03b9\u03c3\u03bc\u03bf\u03c5 \u03c3\u03bf\u03c5 \u03b1 \u03c0\u03c1\u03bf\u03c3\u03b5\u03c4\u03b1\u03be\u03b5\u03bd \u03bc\u03c9\u03c5\u03c3\u03b7\u03c2 \u03b5\u03b9\u03c2 \u03bc\u03b1\u03c1\u03c4\u03c5\u03c1\u03b9\u03bf\u03bd \u03b1\u03c5\u03c4\u03bf\u03b9\u03c2"}, {"pk": 985444, "verse": 45, "text": "\u03bf \u03b4\u03b5 \u03b5\u03be\u03b5\u03bb\u03b8\u03c9\u03bd \u03b7\u03c1\u03be\u03b1\u03c4\u03bf \u03ba\u03b7\u03c1\u03c5\u03c3\u03c3\u03b5\u03b9\u03bd \u03c0\u03bf\u03bb\u03bb\u03b1 \u03ba\u03b1\u03b9 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03b5\u03b9\u03bd \u03c4\u03bf\u03bd \u03bb\u03bf\u03b3\u03bf\u03bd \u03c9\u03c3\u03c4\u03b5 \u03bc\u03b7\u03ba\u03b5\u03c4\u03b9 \u03b1\u03c5\u03c4\u03bf\u03bd \u03b4\u03c5\u03bd\u03b1\u03c3\u03b8\u03b1\u03b9 \u03b5\u03b9\u03c2 \u03c0\u03bf\u03bb\u03b9\u03bd \u03c6\u03b1\u03bd\u03b5\u03c1\u03c9\u03c2 \u03b5\u03b9\u03c3\u03b5\u03bb\u03b8\u03b5\u03b9\u03bd \u03b1\u03bb\u03bb \u03b5\u03be\u03c9 \u03b5\u03c0 \u03b5\u03c1\u03b7\u03bc\u03bf\u03b9\u03c2 \u03c4\u03bf\u03c0\u03bf\u03b9\u03c2 \u03b7\u03bd \u03ba\u03b1\u03b9 \u03b7\u03c1\u03c7\u03bf\u03bd\u03c4\u03bf \u03c0\u03c1\u03bf\u03c2 \u03b1\u03c5\u03c4\u03bf\u03bd \u03c0\u03b1\u03bd\u03c4\u03bf\u03b8\u03b5\u03bd"}]